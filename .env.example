# Copy this file to .env and fill in your values.
#
# iPhone setup:
# 1. Install the free "ntfy" app from the App Store
# 2. Tap + and subscribe to the topic name below (must match exactly)
# 3. Allow notifications when iOS prompts you

# Required: pick a unique private topic name (e.g. njh-aqi-yourname-7f3a)
NTFY_TOPIC=

# Optional: only notify when Max AQI is at or above this value (0 = every reading)
NOTIFY_MIN_AQI=0

# Optional: use a self-hosted ntfy server instead of ntfy.sh
# NTFY_SERVER=https://ntfy.sh

# Optional: bearer token for authenticated/private topics on ntfy.sh Pro or self-hosted
# NTFY_TOKEN=
